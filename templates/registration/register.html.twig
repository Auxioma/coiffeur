{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <div class="row g-0 reg-shell">
        <section class="col-lg-6">
            <div class="reg-form-area px-4 px-sm-5 ps-xl-6 pe-xl-5">
                <div class="mx-auto reg-copy">
                    {% for flash_error in app.flashes('verify_email_error') %}
                        <div class="alert alert-danger reg-alert" role="alert">{{ flash_error }}</div>
                    {% endfor %}

                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success reg-alert" role="alert">{{ message }}</div>
                    {% endfor %}

                    <p class="reg-eyebrow fw-bold text-uppercase mb-3">Join our community</p>
                    <h1 class="reg-serif reg-title fw-bold mb-4">Create your<br>account</h1>
                    <p class="reg-lead mb-5">Create your Luxéa Beauty account to book services, save your favorite professionals and manage your appointments.</p>

                    {{ form_start(registrationForm, { attr: { class: 'reg-form' } }) }}
                        {{ form_errors(registrationForm) }}

                        <div class="row g-4">
                            <div class="col-12">
                                {{ form_label(registrationForm.email, null, { label_attr: { class: 'form-label' } }) }}
                                <div class="input-group">
                                    <span class="input-group-text reg-input-icon"><i class="bi bi-envelope"></i></span>
                                    {{ form_widget(registrationForm.email, { attr: { class: 'form-control reg-control', placeholder: 'Enter your email address', autocomplete: 'email' } }) }}
                                </div>
                                {{ form_errors(registrationForm.email) }}
                            </div>

                            <div class="col-12">
                                {{ form_label(registrationForm.plainPassword, null, { label_attr: { class: 'form-label' } }) }}
                                <div class="input-group">
                                    <span class="input-group-text reg-input-icon"><i class="bi bi-lock"></i></span>
                                    {{ form_widget(registrationForm.plainPassword, { attr: { class: 'form-control reg-control', placeholder: 'Create a secure password', autocomplete: 'new-password' } }) }}
                                </div>
                                <p class="reg-secure-note mt-2 mb-0">Use at least 6 characters. You can complete your profile after sign up.</p>
                                {{ form_errors(registrationForm.plainPassword) }}
                            </div>

                            <div class="col-12">
                                <div class="form-check reg-terms">
                                    {{ form_widget(registrationForm.agreeTerms, { attr: { class: 'form-check-input rounded-1' } }) }}
                                    {{ form_label(registrationForm.agreeTerms, null, { label_attr: { class: 'form-check-label fw-semibold' } }) }}
                                </div>
                                {{ form_errors(registrationForm.agreeTerms) }}
                            </div>

                            <div class="col-12 pt-2">
                                <button class="btn reg-btn-pink w-100 rounded-3 fw-bold py-3" type="submit">Create account</button>
                            </div>

                            <div class="col-12 text-center">
                                <p class="mb-0 text-secondary fs-5">Already have an account? <a class="reg-link" href="{{ path('app_login') }}">Log in</a></p>
                            </div>
                        </div>
                    {{ form_end(registrationForm) }}
                </div>
            </div>
        </section>

        <aside class="col-lg-6 position-relative reg-media d-flex align-items-end" id="registerVisual" style="--reg-bg: url('data:image/jpeg;base64,');">
            <div class="card reg-benefits position-absolute rounded-4 overflow-hidden">
                <div class="card-body p-0">
                    <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-4 g-0 text-center">
                        <div class="col p-4">
                            <div class="reg-benefit-icon rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                                <i class="bi bi-people fs-3"></i>
                            </div>
                            <p class="fw-bold fs-5 mb-0">Reach thousands<br>of clients</p>
                        </div>
                        <div class="col p-4">
                            <div class="reg-benefit-icon rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                                <i class="bi bi-calendar2-check fs-3"></i>
                            </div>
                            <p class="fw-bold fs-5 mb-0">Manage bookings<br>with ease</p>
                        </div>
                        <div class="col p-4">
                            <div class="reg-benefit-icon rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                                <i class="bi bi-graph-up-arrow fs-3"></i>
                            </div>
                            <p class="fw-bold fs-5 mb-0">Grow your<br>business</p>
                        </div>
                        <div class="col p-4">
                            <div class="reg-benefit-icon rounded-circle d-inline-flex align-items-center justify-content-center mb-3">
                                <i class="bi bi-shield-check fs-3"></i>
                            </div>
                            <p class="fw-bold fs-5 mb-0">Secure & trusted<br>platform</p>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
    <script>
        const registerImages = {
            account: "data:image/jpeg;base64,",
            business: "data:image/jpeg;base64,",
            verification: "data:image/jpeg;base64,"
        };

        const visual = document.getElementById('registerVisual');

        document.querySelectorAll('[data-bs-toggle="tab"][data-reg-bg]').forEach((tabButton) => {
            tabButton.addEventListener('shown.bs.tab', (event) => {
                const key = event.target.getAttribute('data-reg-bg');
                if (registerImages[key]) {
                    visual.style.setProperty('--reg-bg', `url('${registerImages[key]}')`);
                }
            });
        });

        document.querySelectorAll('[data-next-tab]').forEach((button) => {
            button.addEventListener('click', () => {
                const target = document.querySelector(button.getAttribute('data-next-tab'));
                if (target) {
                    bootstrap.Tab.getOrCreateInstance(target).show();
                }
            });
        });

        document.querySelectorAll('[data-toggle-password]').forEach((button) => {
            button.addEventListener('click', () => {
                const input = document.querySelector(button.getAttribute('data-toggle-password'));
                const icon = button.querySelector('i');
                if (!input) return;
                input.type = input.type === 'password' ? 'text' : 'password';
                icon.classList.toggle('bi-eye');
                icon.classList.toggle('bi-eye-slash');
            });
        });

        const businessDescription = document.getElementById('businessDescription');
        const descriptionCount = document.getElementById('descriptionCount');

        if (businessDescription && descriptionCount) {
            businessDescription.addEventListener('input', () => {
                descriptionCount.textContent = businessDescription.value.length;
            });
        }

        const identityFile = document.getElementById('identityFile');
        const fileName = document.getElementById('fileName');

        if (identityFile && fileName) {
            identityFile.addEventListener('change', () => {
                fileName.textContent = identityFile.files.length ? identityFile.files[0].name : '';
            });
        }
    </script>
{% endblock %}
