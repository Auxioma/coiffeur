<header id="hero" class="hero-section border-bottom border-lux">
    <div class="container-xl">
        <div class="row align-items-stretch g-0">
            <div class="col-lg-9 py-5 py-lg-5">
                <div class="py-lg-5 pe-lg-5">
                    <p class="text-gold text-uppercase fw-semibold small mb-3" style="letter-spacing:.18em;">Europe's Premium Beauty Marketplace</p>
                    <h1 class="display-2 fw-semibold lh-1 mb-4">Your Beauty.<br>Your Moment.</h1>
                    <p class="lead text-secondary mb-4">Book trusted beauty &amp; wellness professionals<br class="d-none d-md-block"> near you. Anytime, anywhere.</p>

                    <form class="search-panel bg-white border border-lux shadow rounded-4 p-3 p-lg-4 mb-4">
                        <div class="row g-3 align-items-end">
                            <div class="col-md-3 border-end border-lux">
                                <label class="form-label small fw-semibold mb-1"><i class="bi bi-search me-2 text-secondary"></i>Service</label>
                                <input class="form-control" type="text" value="" placeholder="e.g., Haircut, Massage, Nail Art">
                            </div>
                            <div class="col-md-3 border-end border-lux">
                                <label class="form-label small fw-semibold mb-1"><i class="bi bi-geo-alt me-2 text-secondary"></i>Location</label>
                                <input class="form-control" type="text" placeholder="e.g., Paris, Berlin, Milan">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-semibold mb-1"><i class="bi bi-calendar3 me-2 text-secondary"></i>Date</label>
                                <input class="form-control" type="text" placeholder="Select date">
                            </div>
                            <div class="col-md-3 d-grid">
                                <button class="btn btn-primary rounded-3 py-3" type="button">Search</button>
                            </div>
                        </div>
                    </form>

                    <div class="row g-4">

                        <div class="col-12 col-sm-4">
                            <div class="d-flex align-items-center gap-3">
                                <span class="icon-mini rounded-circle d-inline-flex align-items-center justify-content-center"><i class="bi bi-patch-check"></i></span>
                                <div>
                                    <p class="fw-semibold small mb-0">Trusted Professionals</p>
                                    <p class="small text-secondary mb-0">Verified & reviewed</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-sm-4">
                            <div class="d-flex align-items-center gap-3">
                                <span class="icon-mini rounded-circle d-inline-flex align-items-center justify-content-center"><i class="bi bi-stars"></i></span>
                                <div>
                                    <p class="fw-semibold small mb-0">Easy Booking</p>
                                    <p class="small text-secondary mb-0">Instant confirmation</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-sm-4">
                            <div class="d-flex align-items-center gap-3">
                                <span class="icon-mini rounded-circle d-inline-flex align-items-center justify-content-center"><i class="bi bi-shield-check"></i></span>
                                <div>
                                    <p class="fw-semibold small mb-0">Secure Payments</p>
                                    <p class="small text-secondary mb-0">Safe & encrypted</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>
