{% extends 'layouts/booking.html.twig' %}
{% set page_title = 'Choix des prestations — Belle Maison' %}
{% set meta_description = 'Tunnel de réservation sans paiement en ligne' %}
{% set main_class = 'bm-booking-main' %}

{% block body %}
<section class="bm-booking-hero">
<div class="container bm-container">
<p class="bm-eyebrow">Réservation sans paiement en ligne</p>
<h1>Choix des prestations</h1>
<p>Choisissez une prestation, un collaborateur et un créneau. La création de compte est demandée uniquement avant la validation finale.</p>
<div class="bm-booking-stepper"><a class="bm-booking-step is-active" href="{{ path('app_booking_service') }}"><span>1</span><em>Prestations</em></a><a class="bm-booking-step" href="{{ path('app_booking_staff') }}"><span>2</span><em>Collaborateur</em></a><a class="bm-booking-step" href="{{ path('app_booking_slot') }}"><span>3</span><em>Créneau</em></a><a class="bm-booking-step" href="{{ path('app_booking_auth') }}"><span>4</span><em>Compte</em></a><a class="bm-booking-step" href="{{ path('app_booking_summary') }}"><span>5</span><em>Validation</em></a></div>
</div>
</section>
<section class="bm-booking-section">
<div class="container bm-container">
<div class="bm-booking-grid">
<div>
<div class="bm-booking-panel"><h2>Choisissez vos prestations</h2><p>Vous pouvez composer un panier de prestations. Le prix reste indicatif et le règlement se fait au salon.</p><div class="bm-booking-service-list"><label class="is-selected"><input checked="" type="checkbox"/><span><strong>Coupe femme + brushing</strong><em>Diagnostic, shampoing, coupe et coiffage.</em></span><b>1h15 · 58 €</b></label><label><input type="checkbox"/><span><strong>Soin profond kératine</strong><em>À ajouter avant ou après la coupe.</em></span><b>45 min · 49 €</b></label><label><input type="checkbox"/><span><strong>Balayage + patine</strong><em>Durée variable selon longueur, diagnostic recommandé.</em></span><b>2h30 · dès 92 €</b></label></div><div class="bm-booking-actions"><a class="btn bm-btn bm-btn-outline" href="{{ path('app_salon_detail') }}">Retour</a><a class="btn bm-btn bm-btn-primary" href="{{ path('app_booking_staff') }}">Continuer</a></div></div></div>
<aside class="bm-booking-summary-card">
<p class="bm-admin-kicker">Votre sélection</p>
<h2>Maison Élégance</h2>
<div class="bm-booking-summary-line"><span>Prestations</span><strong>Coupe femme + brushing</strong></div>
<div class="bm-booking-summary-line"><span>Collaborateur</span><strong>Clara Martin</strong></div>
<div class="bm-booking-summary-line"><span>Date</span><strong>Jeudi 25 juin · 14:30</strong></div>
<div class="bm-booking-summary-line"><span>Durée</span><strong>1h15</strong></div>
<div class="bm-booking-summary-price"><span>Total estimé</span><strong>58 €</strong><small>Paiement sur place le jour du rendez-vous.</small></div>
<a class="bm-link mt-3 d-inline-flex" href="{{ path('app_salon_detail') }}">Retour à la fiche salon</a>
</aside>
</div>
</div>
</section>
{% endblock %}
