{% extends 'base.html.twig' %}

{% block title %}Sign in{% endblock %}

{% block body %}
    <section class="auth-shell">
        <div class="container-xl">
            <div class="auth-card">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success auth-alert" role="alert">{{ message }}</div>
                {% endfor %}

                {% if error %}
                    <div class="alert alert-danger auth-alert" role="alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                {% if app.user %}
                    <div class="alert alert-light auth-alert">
                        You are logged in as {{ app.user.userIdentifier }}, <a class="fw-semibold text-decoration-none" href="{{ logout_path() }}">Log out</a>
                    </div>
                {% endif %}

                <p class="section-kicker text-gold mb-3">Account access</p>
                <h1 class="font-display auth-title fw-semibold mb-3">Sign in to your account</h1>
                <p class="auth-text mb-4">Access your bookings, saved professionals and account settings.</p>

                <form method="post" class="auth-form">
                    <div class="mb-3">
                        <label class="form-label" for="inputEmail">Email</label>
                        <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="inputPassword">Password</label>
                        <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" required>
                    </div>
                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                        <label class="form-check-label" for="rememberMe">Remember me</label>
                    </div>

                    <button class="btn btn-primary" type="submit">Sign in</button>

                    <div class="d-flex flex-column flex-sm-row justify-content-between gap-2 mt-4 auth-links">
                        <a class="fw-semibold text-decoration-none" href="{{ path('app_forgot_password_request') }}">Forgot your password?</a>
                        <a class="fw-semibold text-decoration-none" href="{{ path('app_register') }}">Create an account</a>
                    </div>
                </form>
            </div>
        </div>
    </section>
{% endblock %}
