{% extends 'layouts/account.html.twig' %}
{% set page_title = 'Laisser un avis — Belle Maison' %}
{% set meta_description = 'Partagez votre expérience après votre rendez-vous.' %}
{% set body_class = 'bm-user-body' %}
{% set main_class = 'bm-user-main' %}

{% block body %}
<header class="bm-user-topbar">
<button aria-label="Ouvrir la navigation" class="bm-admin-menu-btn" type="button"><i class="bi bi-list"></i></button>
<div><p class="bm-admin-kicker">Avis client</p><h1>Laisser un avis</h1><span>Partagez votre expérience après votre rendez-vous.</span></div>
<div class="bm-admin-topbar-actions"><a class="btn bm-btn bm-btn-outline" href="{{ path('app_search_results') }}"><i class="bi bi-search me-2"></i>Rechercher</a><a class="btn bm-btn bm-btn-primary" href="{{ path('app_booking_service') }}"><i class="bi bi-calendar-plus me-2"></i>Nouveau RDV</a></div>
</header>
<section class="bm-admin-panel"><h2>Votre avis sur Maison Élégance</h2><div class="bm-review-stars">★★★★★</div><div class="row g-3"><div class="col-md-6"><label>Accueil</label><select class="form-select bm-form-control"><option>5/5</option></select></div><div class="col-md-6"><label>Prestation</label><select class="form-select bm-form-control"><option>5/5</option></select></div><div class="col-12"><label>Commentaire</label><textarea class="form-control bm-form-control" placeholder="Votre expérience" rows="5"></textarea></div></div><div class="bm-booking-actions"><a class="btn bm-btn bm-btn-outline" href="{{ path('app_user_reviews') }}">Annuler</a><button class="btn bm-btn bm-btn-primary">Publier l’avis</button></div></section>
{% endblock %}
