{% extends 'layouts/account.html.twig' %}
{% set page_title = 'Reporter mon RDV — Belle Maison' %}
{% set meta_description = 'Choisissez un autre créneau pour votre rendez-vous.' %}
{% set body_class = 'bm-user-body' %}
{% set main_class = 'bm-user-main' %}

{% block body %}
<header class="bm-user-topbar">
<button aria-label="Ouvrir la navigation" class="bm-admin-menu-btn" type="button"><i class="bi bi-list"></i></button>
<div><p class="bm-admin-kicker">Rendez-vous client</p><h1>Reporter mon RDV</h1><span>Choisissez un autre créneau pour votre rendez-vous.</span></div>
<div class="bm-admin-topbar-actions"><a class="btn bm-btn bm-btn-outline" href="{{ path('app_search_results') }}"><i class="bi bi-search me-2"></i>Rechercher</a><a class="btn bm-btn bm-btn-primary" href="{{ path('app_booking_service') }}"><i class="bi bi-calendar-plus me-2"></i>Nouveau RDV</a></div>
</header>
<section class="bm-admin-panel"><h2>Nouveau créneau</h2><div class="bm-day-strip"><button>Jeu. 25<br/><span>3 créneaux</span></button><button class="is-active">Ven. 26<br/><span>6 créneaux</span></button><button>Sam. 27<br/><span>2 créneaux</span></button></div><div class="bm-slot-grid mt-3"><a>09:30</a><a class="is-selected">14:30</a><a>15:45</a><a>17:00</a></div><div class="bm-booking-actions"><a class="btn bm-btn bm-btn-outline" href="{{ path('app_user_appointment_detail') }}">Retour</a><a class="btn bm-btn bm-btn-primary" href="{{ path('app_user_appointments') }}">Confirmer le report</a></div></section>
{% endblock %}
