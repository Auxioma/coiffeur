{% extends 'layouts/account.html.twig' %}
{% set page_title = 'Supprimer mon compte — Belle Maison' %}
{% set meta_description = 'Demande de suppression définitive du compte client et de ses données.' %}
{% set body_class = 'bm-user-body' %}
{% set main_class = 'bm-user-main' %}

{% block body %}
<header class="bm-user-topbar">
<button aria-label="Ouvrir la navigation" class="bm-admin-menu-btn" type="button"><i class="bi bi-list"></i></button>
<div><p class="bm-admin-kicker">Confidentialité</p><h1>Supprimer mon compte</h1><span>Demande de suppression définitive du compte client et de ses données.</span></div>
<div class="bm-admin-topbar-actions"><a class="btn bm-btn bm-btn-outline" href="{{ path('app_search_results') }}"><i class="bi bi-search me-2"></i>Rechercher</a><a class="btn bm-btn bm-btn-primary" href="{{ path('app_booking_service') }}"><i class="bi bi-calendar-plus me-2"></i>Nouveau RDV</a></div>
</header>
<section class="bm-admin-panel bm-danger-zone"><h2>Suppression du compte</h2><p>Cette action est irréversible. Vos rendez-vous futurs doivent être annulés avant suppression.</p><label class="bm-check"><input type="checkbox"/> Je comprends que cette action est définitive.</label><textarea class="form-control bm-form-control mt-3" placeholder="Motif optionnel" rows="4"></textarea><div class="bm-booking-actions"><a class="btn bm-btn bm-btn-outline" href="{{ path('app_user_security') }}">Annuler</a><button class="btn bm-btn bm-btn-danger">Supprimer définitivement</button></div></section>
{% endblock %}
