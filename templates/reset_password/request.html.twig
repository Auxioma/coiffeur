{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block body %}
    <section class="auth-shell">
        <div class="container-xl">
            <div class="auth-card">
                {% for flash_error in app.flashes('reset_password_error') %}
                    <div class="alert alert-danger auth-alert" role="alert">{{ flash_error }}</div>
                {% endfor %}

                <p class="section-kicker text-gold mb-3">Password assistance</p>
                <h1 class="font-display auth-title fw-semibold mb-3">Reset your password</h1>
                <p class="auth-text mb-4">Enter your email address and we will send you a secure reset link.</p>

                {{ form_start(requestForm, { attr: { class: 'auth-form' } }) }}
                    <div class="mb-4">
                        {{ form_label(requestForm.email, null, { label_attr: { class: 'form-label' } }) }}
                        {{ form_widget(requestForm.email, { attr: { class: 'form-control', placeholder: 'Enter your email address', autocomplete: 'email' } }) }}
                        {{ form_errors(requestForm.email) }}
                    </div>
                    <p class="auth-text mb-4">If an account matches this address, you will receive a reset email in a few moments.</p>
                    <button class="btn btn-primary">Send password reset email</button>
                {{ form_end(requestForm) }}
            </div>
        </div>
    </section>
{% endblock %}
