{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block body %}
    <section class="auth-shell">
        <div class="container-xl">
            <div class="auth-card">
                <p class="section-kicker text-gold mb-3">Password assistance</p>
                <h1 class="font-display auth-title fw-semibold mb-3">Choose a new password</h1>
                <p class="auth-text mb-4">Use a strong password that you do not reuse on other services.</p>

                {{ form_start(resetForm, { attr: { class: 'auth-form' } }) }}
                    <div class="mb-4">
                        {{ form_label(resetForm.plainPassword.first, null, { label_attr: { class: 'form-label' } }) }}
                        {{ form_widget(resetForm.plainPassword.first, { attr: { class: 'form-control', placeholder: 'Create a new password', autocomplete: 'new-password' } }) }}
                        {{ form_errors(resetForm.plainPassword.first) }}
                    </div>
                    <div class="mb-4">
                        {{ form_label(resetForm.plainPassword.second, null, { label_attr: { class: 'form-label' } }) }}
                        {{ form_widget(resetForm.plainPassword.second, { attr: { class: 'form-control', placeholder: 'Repeat your new password', autocomplete: 'new-password' } }) }}
                        {{ form_errors(resetForm.plainPassword.second) }}
                    </div>
                    <button class="btn btn-primary">Reset password</button>
                {{ form_end(resetForm) }}
            </div>
        </div>
    </section>
{% endblock %}
