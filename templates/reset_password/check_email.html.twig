{% extends 'base.html.twig' %}

{% block title %}Password Reset Email Sent{% endblock %}

{% block body %}
    <section class="auth-shell">
        <div class="container-xl">
            <div class="auth-card">
                <p class="section-kicker text-gold mb-3">Password assistance</p>
                <h1 class="font-display auth-title fw-semibold mb-3">Check your inbox</h1>
                <p class="auth-text mb-3">
                    If an account matching your email exists, then an email was just sent that contains a link that you can use to reset your password.
                    This link will expire in {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
                </p>
                <p class="auth-text mb-0">If you don't receive an email, please check your spam folder or <a class="fw-semibold text-decoration-none" href="{{ path('app_forgot_password_request') }}">try again</a>.</p>
            </div>
        </div>
    </section>
{% endblock %}
