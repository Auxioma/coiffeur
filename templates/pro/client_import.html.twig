{% extends 'layouts/admin.html.twig' %}
{% set page_title = 'Importer des clients — Belle Maison Pro' %}
{% set meta_description = 'Importer un fichier CSV avec coordonnées, tags et consentements.' %}

{% block body %}
<header class="bm-admin-topbar">
<button aria-label="Ouvrir la navigation" class="bm-admin-menu-btn" type="button"><i class="bi bi-list"></i></button>
<div><p class="bm-admin-kicker">CRM</p><h1>Importer des clients</h1><span>Importer un fichier CSV avec coordonnées, tags et consentements.</span></div>
<div class="bm-admin-topbar-actions"><a class="btn bm-btn bm-btn-primary" href="{{ path('app_agenda_pro') }}"><i class="bi bi-plus-lg me-2"></i>Nouveau RDV</a></div>
</header>
<section class="bm-admin-panel"><h2>Import CSV</h2><div class="bm-upload-box"><i class="bi bi-cloud-arrow-up"></i><strong>Déposez votre fichier CSV</strong><span>Colonnes attendues : nom, prénom, email, téléphone, consentement marketing.</span></div><button class="btn bm-btn bm-btn-primary mt-4">Lancer l’import</button></section>
{% endblock %}
