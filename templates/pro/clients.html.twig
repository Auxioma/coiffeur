{% extends 'layouts/admin.html.twig' %}
{% set page_title = 'Clients & mini-CRM — Belle Maison Pro' %}
{% set meta_description = 'Interface professionnelle Belle Maison' %}

{% block body %}
<header class="bm-admin-topbar">
<button aria-label="Ouvrir la navigation" class="bm-admin-menu-btn" type="button"><i class="bi bi-list"></i></button>
<div>
<p class="bm-admin-kicker">Espace professionnel</p>
<h1>Clients &amp; mini-CRM</h1>
<span>Recherche, filtres, segmentation, export et fusion de doublons.</span>
</div>
<div class="bm-admin-topbar-actions">
<button class="btn bm-btn bm-btn-soft" type="button"><i class="bi bi-search me-2"></i>Rechercher</button>
<button class="btn bm-btn bm-btn-soft" type="button"><i class="bi bi-bell me-2"></i>Alertes</button>
<a class="btn bm-btn bm-btn-primary" href="#"><i class="bi bi-plus-lg me-2"></i>Nouveau client</a>
</div>
</header>
<section class="bm-admin-panel">
<div class="bm-admin-panel-head"><div><h2>Liste clients</h2><p>Coordonnées, historique, tags, consentement RGPD et notes professionnelles.</p></div><div class="bm-admin-actions-row"><button class="btn bm-btn bm-btn-soft">Exporter CSV</button><button class="btn bm-btn bm-btn-primary">Nouveau client</button></div></div>
<div class="bm-admin-filterbar"><input class="form-control bm-form-control" placeholder="Rechercher un client, un tag, un email"/><select class="form-select bm-form-control"><option>Dernière visite</option></select><select class="form-select bm-form-control"><option>Dépense totale</option></select><select class="form-select bm-form-control"><option>Tag</option></select></div>
<div class="table-responsive"><table class="table bm-admin-table"><thead><tr><th>Client</th><th>Segment</th><th>Historique</th><th>Panier total</th><th>Consentement</th><th></th></tr></thead><tbody>
<tr><td><strong>Marine L.</strong><span>marine@example.com</span></td><td>VIP</td><td>12 visites</td><td>648 €</td><td><em class="bm-status bm-status-success">Marketing OK</em></td><td><a class="bm-link" href="{{ path('app_client_detail_pro') }}">Ouvrir</a></td></tr>
<tr><td><strong>Julien M.</strong><span>julien@example.com</span></td><td>Barbier</td><td>5 visites</td><td>215 €</td><td><em class="bm-status bm-status-info">SMS uniquement</em></td><td><a class="bm-link" href="{{ path('app_client_detail_pro') }}">Ouvrir</a></td></tr>
<tr><td><strong>Camille B.</strong><span>camille@example.com</span></td><td>Coloration</td><td>3 visites</td><td>420 €</td><td><em class="bm-status bm-status-warning">Consentement photo à vérifier</em></td><td><a class="bm-link" href="{{ path('app_client_detail_pro') }}">Ouvrir</a></td></tr></tbody></table></div>
</section>
{% endblock %}
