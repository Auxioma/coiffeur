{% extends 'layouts/admin.html.twig' %}
{% set page_title = 'Paramètres établissement — Belle Maison Pro' %}
{% set meta_description = 'Interface professionnelle Belle Maison' %}

{% block body %}
<header class="bm-admin-topbar">
<button aria-label="Ouvrir la navigation" class="bm-admin-menu-btn" type="button"><i class="bi bi-list"></i></button>
<div>
<p class="bm-admin-kicker">Espace professionnel</p>
<h1>Paramètres établissement</h1>
<span>Logo, photos, description, réseaux, facturation SaaS, connecteurs et widget.</span>
</div>
<div class="bm-admin-topbar-actions">
<button class="btn bm-btn bm-btn-soft" type="button"><i class="bi bi-search me-2"></i>Rechercher</button>
<button class="btn bm-btn bm-btn-soft" type="button"><i class="bi bi-bell me-2"></i>Alertes</button>
</div>
</header>
<section class="bm-admin-grid bm-admin-grid-main"><article class="bm-admin-panel"><h2>Informations générales</h2><form class="bm-admin-form-grid"><label>Nom commercial<input class="form-control bm-form-control" value="Maison Élégance"/></label><label>Téléphone<input class="form-control bm-form-control" value="02 35 00 00 00"/></label><label class="bm-span-2">Adresse<input class="form-control bm-form-control" value="12 rue de Paris, 76600 Le Havre"/></label><label class="bm-span-2">Description<textarea class="form-control bm-form-control" rows="4">Salon premium spécialisé en coiffure, balayage et soins personnalisés.</textarea></label></form></article><aside class="bm-admin-panel"><h2>Connecteurs</h2><div class="bm-template-list"><div><strong>Google Calendar</strong><span>Synchronisation bidirectionnelle</span><em class="bm-status bm-status-success">Connecté</em></div><div><strong>Google Business Profile</strong><span>Avis et visibilité locale</span><em class="bm-status bm-status-warning">À connecter</em></div><div><strong>Widget site externe</strong><span>Code d’intégration</span><em class="bm-status bm-status-info">Disponible</em></div></div></aside></section>
{% endblock %}
