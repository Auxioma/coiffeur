{% extends 'layouts/admin.html.twig' %}
{% set page_title = 'Modifier un client — Belle Maison Pro' %}
{% set meta_description = 'Mettre à jour coordonnées, tags et notes professionnelles.' %}

{% block body %}
<header class="bm-admin-topbar">
<button aria-label="Ouvrir la navigation" class="bm-admin-menu-btn" type="button"><i class="bi bi-list"></i></button>
<div><p class="bm-admin-kicker">Espace professionnel</p><h1>Modifier un client</h1><span>Mettre à jour coordonnées, tags et notes professionnelles.</span></div>
<div class="bm-admin-topbar-actions"><a class="btn bm-btn bm-btn-primary" href="{{ path('app_agenda_pro') }}"><i class="bi bi-plus-lg me-2"></i>Nouveau RDV</a></div>
</header>
<section class="bm-admin-panel"><h2>Modifier un client</h2><p>Mettre à jour coordonnées, tags et notes professionnelles.</p><div class="row g-3"><div class="col-md-6"><label>Prénom</label><input class="form-control bm-form-control" value="Marine"/></div><div class="col-md-6"><label>Nom</label><input class="form-control bm-form-control" value="Laurent"/></div><div class="col-md-6"><label>Email</label><input class="form-control bm-form-control" value="marine@example.com"/></div><div class="col-md-6"><label>Téléphone</label><input class="form-control bm-form-control" value="06 12 34 56 78"/></div><div class="col-12"><label>Notes professionnelles</label><textarea class="form-control bm-form-control" rows="4">Allergie à vérifier avant coloration.</textarea></div><div class="bm-booking-actions"><button class="btn bm-btn bm-btn-outline">Annuler</button><button class="btn bm-btn bm-btn-primary">Enregistrer</button></div></div></section>
{% endblock %}
