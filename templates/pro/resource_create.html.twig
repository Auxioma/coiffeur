{% extends 'layouts/admin.html.twig' %}
{% set page_title = 'Ajouter une ressource — Belle Maison Pro' %}
{% set meta_description = 'Configurez une ressource physique utilisée par les rendez-vous.' %}

{% block body %}
<header class="bm-admin-topbar">
<button aria-label="Ouvrir la navigation" class="bm-admin-menu-btn" type="button"><i class="bi bi-list"></i></button>
<div><p class="bm-admin-kicker">Ressources</p><h1>Ajouter une ressource</h1><span>Configurez une ressource physique utilisée par les rendez-vous.</span></div>
<div class="bm-admin-topbar-actions"><a class="btn bm-btn bm-btn-primary" href="{{ path('app_agenda_pro') }}"><i class="bi bi-plus-lg me-2"></i>Nouveau RDV</a></div>
</header>
<section class="bm-admin-panel"><h2>Ajouter une ressource</h2><div class="row g-3"><div class="col-md-6"><label>Nom</label><input class="form-control bm-form-control" value="Cabine soin visage"/></div><div class="col-md-6"><label>Type</label><input class="form-control bm-form-control" value="Cabine"/></div><div class="col-md-6"><label>Capacité simultanée</label><input class="form-control bm-form-control" value="1"/></div><div class="col-md-6"><label>Prestations liées</label><input class="form-control bm-form-control" value="Soin visage, massage"/></div><div class="col-12"><label>Notes</label><textarea class="form-control bm-form-control" rows="3"></textarea></div><div class="bm-booking-actions"><button class="btn bm-btn bm-btn-outline">Annuler</button><button class="btn bm-btn bm-btn-primary">Enregistrer</button></div></div></section>
{% endblock %}
